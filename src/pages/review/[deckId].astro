---
import { env } from 'cloudflare:workers'
import Base from '@/layouts/Base.astro'
import { ReviewFlow, ReviewEmpty } from '@/components/ReviewFlow'
import { ExamResult } from '@/components/ExamResult'
import { renderQuestionMarkdown, renderExplanationMarkdown } from '@/lib/markdown'

const { deckId } = Astro.params
const mode = Astro.url.searchParams.get('mode')
const examIndex = parseInt(Astro.url.searchParams.get('q') || '0')
const examSession = Astro.url.searchParams.get('session')

const db = env.DB
const today = new Date().toISOString().split('T')[0]

const deck = await db.prepare('SELECT * FROM decks WHERE id = ?')
	.bind(deckId!).first<{ id: string; name: string }>()

if (!deck) {
	return Astro.redirect('/')
}

// 試験の問題数を取得
const examRow = await db.prepare('SELECT total_questions FROM exams WHERE id = (SELECT exam_id FROM decks WHERE id = ?)')
	.bind(deckId!).first<{ total_questions: number | null }>()
const examQuestionCount = examRow?.total_questions ?? 65

const totalRow = await db.prepare(
	'SELECT COUNT(*) as cnt FROM cards WHERE deck_id = ?'
).bind(deckId!).first<{ cnt: number }>()

const reviewedRow = await db.prepare(
	'SELECT COUNT(*) as cnt FROM reviews r JOIN cards c ON r.card_id = c.id WHERE c.deck_id = ?'
).bind(deckId!).first<{ cnt: number }>()

let card: any = null
let isExamMode = mode === 'exam'
let examTotal = examQuestionCount

if (isExamMode) {
	// 模擬試験モード: sessionパラメータでランダムシードを固定
	// 同じsessionなら同じ問題セットが出る
	const seed = examSession || crypto.randomUUID().slice(0, 8)
	if (!examSession) {
		// 新規セッション開始 → リダイレクト
		return Astro.redirect(`/review/${deckId}?mode=exam&session=${seed}&q=0`)
	}

	// セッションのシードでランダムに65問取得 (SQLiteのRANDOMはシード不可なのでhash的に並べる)
	const { results: examCards } = await db.prepare(
		`SELECT id FROM cards WHERE deck_id = ? ORDER BY hex(id || ?) LIMIT ?`
	).bind(deckId!, seed, examTotal).all()

	if (examIndex >= examCards.length) {
		// 全問完了
		card = null
	} else {
		const targetId = (examCards[examIndex] as any).id
		card = await db.prepare('SELECT * FROM cards WHERE id = ?')
			.bind(targetId).first()
	}
} else if (mode !== 'new') {
	// 通常モード: 復習カード優先
	card = await db.prepare(
		'SELECT c.* FROM reviews r JOIN cards c ON r.card_id = c.id WHERE c.deck_id = ? AND r.next_review <= ? ORDER BY r.next_review ASC LIMIT 1'
	).bind(deckId!, today).first()
}

if (!card && !isExamMode) {
	// 新規カード
	card = await db.prepare(
		'SELECT c.* FROM cards c WHERE c.deck_id = ? AND c.id NOT IN (SELECT card_id FROM reviews) ORDER BY c.id LIMIT 1'
	).bind(deckId!).first()
}

let options: any[] = []
let answers: any[] = []
let topicName: string | null = null

if (card) {
	const optResult = await db.prepare(
		'SELECT * FROM card_options WHERE card_id = ? ORDER BY group_name, position'
	).bind(card.id).all()
	options = optResult.results as any[]

	const ansResult = await db.prepare(
		'SELECT * FROM card_answers WHERE card_id = ?'
	).bind(card.id).all()
	answers = ansResult.results as any[]

	if (card.topic_id) {
		const topic = await db.prepare(
			'SELECT name FROM exam_topics WHERE id = ?'
		).bind(card.topic_id).first<{ name: string }>()
		topicName = topic?.name ?? null
	}
}

// SSRでMarkdownをHTMLに変換
let questionHtml = ''
let explanationHtml = ''
if (card) {
	questionHtml = await renderQuestionMarkdown(card.question, card.type)
	if (card.explanation) {
		explanationHtml = await renderExplanationMarkdown(card.explanation)
	}
}

const progressCurrent = isExamMode ? examIndex : (reviewedRow?.cnt ?? 0)
const progressTotal = isExamMode ? examTotal : (totalRow?.cnt ?? 0)
const nextUrl = isExamMode
	? `/review/${deckId}?mode=exam&session=${examSession}&q=${examIndex + 1}`
	: `/review/${deckId}`

// 模擬試験完了時のスコア計算
let examCorrectCount = 0
if (isExamMode && !card) {
	const scoreRow = await db.prepare(
		'SELECT COUNT(*) as cnt FROM reviews r JOIN cards c ON r.card_id = c.id WHERE c.deck_id = ? AND r.last_quality >= 3'
	).bind(deckId!).first<{ cnt: number }>()
	examCorrectCount = Math.min(scoreRow?.cnt ?? 0, examTotal)
}
---

<Base title={`${deck.name} — ${isExamMode ? '模擬試験' : '学習'}`}>
	{card ? (
		<ReviewFlow
			client:load
			deckId={deckId!}
			deckName={deck.name}
			card={card}
			options={options}
			answers={answers}
			topicName={topicName}
			progressCurrent={progressCurrent}
			progressTotal={progressTotal}
			questionHtml={questionHtml}
			explanationHtml={explanationHtml}
			nextUrl={nextUrl}
			isExamMode={isExamMode}
		/>
	) : isExamMode ? (
		<div class="fade-in">
			<ExamResult
				client:load
				deckId={deckId!}
				deckName={deck.name}
				totalQuestions={examTotal}
				correctCount={examCorrectCount}
				passingScore={65}
			/>
		</div>
	) : (
		<ReviewEmpty client:load deckId={deckId!} deckName={deck.name} />
	)}
</Base>

<style is:global>
	.exam-complete .btn-restart, .exam-complete .btn-back {
		display: inline-flex;
		padding: 12px 24px;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		font-size: 14px;
		transition: 0.2s;
	}
	.btn-restart {
		background: #6366f1;
		color: #fff;
	}
	.btn-restart:hover { background: #818cf8; }
	.btn-back {
		background: var(--kumo-color-background-raised, #1e1e2e);
		color: var(--kumo-color-text-default);
		border: 1px solid var(--kumo-color-border-default, #2a2a3e);
	}
	.btn-back:hover { background: rgba(99,102,241,0.06); }

	/* 既存スタイルは省略せず保持 */
	.option-btn { display: flex; align-items: flex-start; gap: 14px; padding: 16px 18px; background: var(--kumo-color-background-raised, #1e1e2e); border: 2px solid var(--kumo-color-border-default, #2a2a3e); border-radius: 8px; cursor: pointer; transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1); text-align: left; font-size: 15px; color: var(--kumo-color-text-default, #e4e4ed); line-height: 1.6; width: 100%; font-family: inherit; }
	.option-btn:hover:not(:disabled) { background: rgba(99,102,241,0.06); border-color: rgba(99,102,241,0.4); }
	.option-btn.selected { background: rgba(99,102,241,0.12); border-color: var(--kumo-color-border-focus, #6366f1); }
	.option-btn.correct { background: rgba(74,222,128,0.08); border-color: #4ade80; }
	.option-btn.incorrect { background: rgba(248,113,113,0.08); border-color: #f87171; }
	.option-btn:disabled { cursor: default; }

	.select-hint {
		font-size: 12px;
		color: #6b7280;
		margin-bottom: 10px;
		text-align: center;
	}

	.option-indicator {
		flex-shrink: 0;
		width: 22px; height: 22px;
		display: flex; align-items: center; justify-content: center;
		transition: 0.2s;
		color: transparent;
	}
	.option-indicator.radio {
		border-radius: 50%;
		border: 2px solid #4b5563;
	}
	.option-indicator.checkbox {
		border-radius: 4px;
		border: 2px solid #4b5563;
	}
	.option-indicator.selected { border-color: #6366f1; color: #fff; background: #6366f1; }
	.option-indicator.correct { border-color: #4ade80; color: #fff; background: #4ade80; }
	.option-indicator.incorrect { border-color: #f87171; color: #fff; background: #f87171; }
	.radio-dot { width: 8px; height: 8px; border-radius: 50%; background: #fff; }

	.option-content { flex: 1; display: flex; flex-direction: column; gap: 4px; }
	.option-explanation {
		font-size: 12px;
		line-height: 1.5;
		padding: 6px 10px;
		border-radius: 4px;
		margin-top: 4px;
	}
	.option-explanation.correct { color: #86efac; background: rgba(74,222,128,0.08); }
	.option-explanation.incorrect { color: #fca5a5; background: rgba(248,113,113,0.08); }

	/* Matching Game */
	.matching-container {
		position: relative;
		display: flex;
		gap: 0;
		align-items: flex-start;
		margin-bottom: 8px;
	}
	.matching-col {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.matching-gap { width: 60px; flex-shrink: 0; }
	@media (max-width: 640px) { .matching-gap { width: 30px; } }
	.matching-col-label {
		font-size: 11px;
		font-weight: 600;
		color: #6b7280;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0 4px 4px;
	}
	.matching-item {
		padding: 12px 14px;
		background: #1e1e2e;
		border: 2px solid #2a2a42;
		border-radius: 10px;
		font-size: 14px;
		line-height: 1.5;
		cursor: pointer;
		transition: 0.2s;
		position: relative;
		display: flex;
		align-items: center;
		gap: 10px;
		user-select: none;
	}
	.matching-item:hover:not(.correct):not(.incorrect) {
		border-color: #4b5563;
		background: #22223a;
	}
	.matching-item.active {
		border-color: #6366f1;
		background: rgba(99,102,241,0.12);
		box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
	}
	.matching-item.matched {
		border-color: #6366f1;
		background: rgba(99,102,241,0.08);
	}
	.matching-item.correct {
		border-color: #4ade80;
		background: rgba(74,222,128,0.08);
		cursor: default;
	}
	.matching-item.incorrect {
		border-color: #f87171;
		background: rgba(248,113,113,0.08);
		cursor: default;
	}
	.matching-item.hoverable:hover {
		border-color: #818cf8;
		background: rgba(99,102,241,0.1);
	}
	.matching-label {
		flex-shrink: 0;
		width: 24px;
		height: 24px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 6px;
		font-weight: 700;
		font-size: 12px;
		background: rgba(255,255,255,0.06);
		color: #9ca3af;
	}
	.matching-dot {
		position: absolute;
		right: -8px;
		top: 50%;
		transform: translateY(-50%);
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #6366f1;
		border: 2px solid #1a1a2e;
	}
	.matching-dot-left {
		position: absolute;
		left: -8px;
		top: 50%;
		transform: translateY(-50%);
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #6366f1;
		border: 2px solid #1a1a2e;
		opacity: 0;
	}
	.matching-item.matched .matching-dot-left { opacity: 1; }
	.matching-item.correct .matching-dot,
	.matching-item.correct .matching-dot-left { background: #4ade80; }
	.matching-item.incorrect .matching-dot,
	.matching-item.incorrect .matching-dot-left { background: #f87171; }

	/* Flip animation */
	.flip-container { perspective: 1000px; }
	.flip-card { animation: flipIn 0.5s ease-out; }
	@keyframes flipIn {
		from { transform: rotateX(-90deg); opacity: 0; }
		to { transform: rotateX(0); opacity: 1; }
	}

	/* Result banner */
	.result-banner {
		padding: 14px 18px;
		margin-bottom: 16px;
		border-radius: 10px;
		display: flex;
		align-items: center;
		gap: 10px;
		font-weight: 700;
		font-size: 16px;
	}
	.result-banner.correct {
		background: rgba(74,222,128,0.1);
		border: 1px solid rgba(74,222,128,0.3);
		color: #4ade80;
	}
	.result-banner.incorrect {
		background: rgba(248,113,113,0.1);
		border: 1px solid rgba(248,113,113,0.3);
		color: #f87171;
	}

	/* Explanation box */
	.explanation-box {
		background: #1a1a2e;
		border: 1px solid #2a2a42;
		border-radius: 10px;
		padding: 24px;
		margin-bottom: 20px;
	}
	.explanation-label {
		font-size: 11px;
		color: #6b7280;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 12px;
		font-weight: 600;
	}
	.source-link {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 12px;
		color: #6366f1;
		text-decoration: none;
	}
	.source-link:hover { text-decoration: underline; }
	.flag-btn {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 12px;
		color: #6b7280;
		background: none;
		border: none;
		cursor: pointer;
		margin-left: auto;
		padding: 4px 8px;
		border-radius: 4px;
	}
	.flag-btn:disabled { color: #4ade80; cursor: default; }
	.next-btn {
		display: flex !important;
		align-items: center;
		justify-content: center;
		gap: 8px;
	}

	/* Ordering */
	.ordering-label {
		font-size: 13px;
		color: #6b7280;
		margin-bottom: 12px;
		text-align: center;
	}
	.ordering-list { display: flex; flex-direction: column; gap: 8px; }
	.ordering-item {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 14px 16px;
		background: #1e1e2e;
		border: 2px solid #2a2a42;
		border-radius: 10px;
		cursor: grab;
		transition: 0.2s;
		user-select: none;
		font-size: 14px;
	}
	.ordering-item:active { cursor: grabbing; }
	.ordering-item.dragging { opacity: 0.3; }
	.ordering-item.drag-over {
		border-color: #6366f1;
		transform: scale(1.02);
		box-shadow: 0 4px 16px rgba(99,102,241,0.15);
	}
	.ordering-item.correct { border-color: #4ade80; background: rgba(74,222,128,0.08); }
	.ordering-item.incorrect { border-color: #f87171; background: rgba(248,113,113,0.08); }
	.ordering-handle { color: #4b5563; font-size: 18px; cursor: grab; flex-shrink: 0; }
	.ordering-number {
		width: 24px; height: 24px;
		display: flex; align-items: center; justify-content: center;
		border-radius: 6px;
		font-weight: 700; font-size: 12px;
		background: rgba(255,255,255,0.06);
		color: #9ca3af;
		flex-shrink: 0;
	}
	.ordering-body { flex: 1; }

	.tag {
		display: inline-block;
		font-size: 11px;
		font-weight: 600;
		padding: 3px 10px;
		border-radius: 4px;
		letter-spacing: 0.03em;
	}
	.tag-purple { background: rgba(99,102,241,0.15); color: #a5b4fc; }
	.tag-gray { background: rgba(148,163,184,0.12); color: #94a3b8; }

	.progress-bar {
		width: 100%;
		height: 4px;
		background: #2a2a42;
		border-radius: 2px;
		overflow: hidden;
	}
	.progress-fill {
		height: 100%;
		background: #6366f1;
		border-radius: 2px;
		transition: width 0.5s ease;
	}

	.submit-btn {
		width: 100% !important;
		padding: 16px 24px !important;
		font-size: 16px !important;
		font-weight: 700 !important;
		border-radius: 10px !important;
	}
	.option-label { flex-shrink: 0; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-weight: 700; font-size: 13px; background: rgba(255,255,255,0.06); color: var(--kumo-color-text-subtle, #8888a4); transition: 0.2s; }
	.option-label.selected { background: #6366f1; color: #fff; }
	.option-label.correct { background: #4ade80; color: #000; }
	.option-label.incorrect { background: #f87171; color: #fff; }
	.option-body { flex: 1; padding-top: 3px; }
	.result-icon { flex-shrink: 0; margin-left: auto; padding-top: 3px; }
	.rating-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
	@media (max-width: 640px) { .rating-grid { grid-template-columns: repeat(2, 1fr); } }
	.rating-btn { padding: 14px 8px; background: var(--kumo-color-background-raised, #1e1e2e); border: 1px solid var(--kumo-color-border-default, #2a2a3e); border-radius: 8px; cursor: pointer; text-align: center; transition: 0.2s; color: var(--kumo-color-text-default, #e4e4ed); font-family: inherit; }
	.rating-btn:hover:not(:disabled) { background: rgba(99,102,241,0.06); border-color: rgba(99,102,241,0.4); }
	.rating-btn:disabled { opacity: 0.4; cursor: default; }
	.rating-num { font-size: 22px; font-weight: 700; display: block; margin-bottom: 4px; }
	.rating-label { font-size: 11px; color: var(--kumo-color-text-subtle); display: block; }
</style>
