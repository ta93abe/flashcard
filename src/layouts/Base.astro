---
interface Props {
	title?: string
}

const { title } = Astro.props
const pageTitle = title ? `${title} — Flashcard` : 'Flashcard'
---

<html lang="ja" data-mode="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{pageTitle}</title>
	</head>
	<body>
		<header>
			<div class="container">
				<a href="/" class="logo">Flashcard</a>
			</div>
		</header>
		<main>
			<div class="container">
				<slot />
			</div>
		</main>
		<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "3d7f279a7c9943658ea2055c95ea585c"}'></script>
	</body>
</html>

<style is:global>
	@import "@cloudflare/kumo/styles/standalone";

	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	:root {
		color-scheme: dark;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans JP', sans-serif;
		background: var(--kumo-color-background-default, #0f0f13);
		color: var(--kumo-color-text-default, #e4e4ed);
		line-height: 1.7;
		min-height: 100dvh;
		-webkit-font-smoothing: antialiased;
	}

	.container {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 20px;
	}

	header {
		padding: 20px 0;
		border-bottom: 1px solid var(--kumo-color-border-default, #2a2a3e);
		margin-bottom: 32px;
	}

	header .container {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		color: var(--kumo-color-text-default, #e4e4ed);
		text-decoration: none;
		font-weight: 700;
		font-size: 18px;
		letter-spacing: -0.02em;
	}

	.header-badge {
		font-size: 11px;
		color: var(--kumo-color-text-subtle, #8888a4);
		background: var(--kumo-color-background-raised, #1a1a24);
		padding: 4px 10px;
		border-radius: 100px;
		border: 1px solid var(--kumo-color-border-default, #2a2a3e);
	}

	main { padding-bottom: 80px; }

	h1 {
		font-size: 28px;
		font-weight: 800;
		letter-spacing: -0.03em;
		margin-bottom: 8px;
	}

	code {
		font-family: 'SF Mono', 'Fira Code', monospace;
		background: rgba(99,102,241,0.1);
		padding: 2px 6px;
		border-radius: 4px;
		font-size: 0.9em;
	}

	pre {
		background: #12121a;
		border: 1px solid var(--kumo-color-border-default, #2a2a3e);
		border-radius: 8px;
		padding: 16px;
		overflow-x: auto;
		font-size: 13px;
		line-height: 1.5;
		margin: 12px 0;
	}

	pre code { background: none; padding: 0; }

	.prose p { margin: 0.5em 0; }
	.prose ul, .prose ol { margin: 0.5em 0; padding-left: 1.5em; }
	.prose li { margin: 0.25em 0; }
	.prose table { border-collapse: collapse; margin: 12px 0; width: 100%; font-size: 14px; }
	.prose th, .prose td { border: 1px solid var(--kumo-color-border-default, #2a2a3e); padding: 8px 12px; text-align: left; }
	.prose th { background: rgba(255,255,255,0.04); font-weight: 600; }

	@media (max-width: 640px) {
		h1 { font-size: 22px; }
		.container { padding: 0 16px; }
	}

	.fade-in { animation: fadeIn 0.3s ease-out; }

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(8px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
