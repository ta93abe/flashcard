{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flashcard",
  "compatibility_date": "2026-04-05",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flashcard-db",
      "database_id": "b22d5e71-13b7-47ed-a30a-84176c97e079"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "flashcard-bucket"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}